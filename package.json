{
  "name": "ruxi",
  "version": "1.4.2",
  "description": "Instala Windows en minutos. Sin complicaciones. Para todos.",
  "main": "electron/app/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:portable": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis",
    "build:all": "electron-builder --win portable nsis"
  },
  "devDependencies": {
    "electron": "^22.3.27",
    "electron-builder": "^24.13.3",
    "qrcode-generator": "^2.0.4"
  },
  "build": {
    "appId": "com.poxi.ruxi",
    "productName": "Ruxi",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "PoxiiTV",
      "repo": "Ruxi-Custom-Rufus"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "icon": "electron/app/renderer/assets/logo.ico",
      "requestedExecutionLevel": "requireAdministrator",
      "extraResources": [
        {
          "from": "build/rufus-engine.exe",
          "to": "rufus-engine.exe"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/app/renderer/assets/logo.ico",
      "uninstallerIcon": "electron/app/renderer/assets/logo.ico",
      "installerHeaderIcon": "electron/app/renderer/assets/logo.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ruxi",
      "artifactName": "Ruxi-Setup-${version}.exe"
    },
    "portable": {
      "artifactName": "Ruxi-Portable.exe",
      "requestExecutionLevel": "admin"
    },
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      {
        "target": "portable",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
